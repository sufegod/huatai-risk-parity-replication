# Copy this file to `.env` and fill in local-only secrets.
# `.env` is ignored by Git and must not be committed.

# JYDB / SQL Server connection
JYDB_DRIVER="ODBC Driver 17 for SQL Server"
JYDB_SERVER="192.168.10.48"
JYDB_DATABASE="JYDB"
JYDB_UID="tsreadonly"
JYDB_PWD="<填写真实数据库密码>"

# iFinD MCP connection
IFIND_MCP_URL="<填写iFinD MCP URL>"
IFIND_MCP_AUTHORIZATION="<填写Authorization完整值，例如 Bearer xxxxxx>"
